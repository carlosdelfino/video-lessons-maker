# Environment Variables Example
# Copy this file to .env or a custom .env file and configure your values

# Course Language Configuration
# Options: pt-br (Portuguese - default), en (English), es (Spanish), fr (French), de (German)
# When set to pt-br, original files are used without suffix
# When set to other languages, translated files are created with language suffix
COURSE_LANGUAGE=pt-br

# OpenAI API Configuration
OPENAI_API_KEY=your_openai_api_key_here

# Google Cloud TTS Configuration
GOOGLE_APPLICATION_CREDENTIALS=/path/to/your/google-credentials.json

# Optional: Custom output directories
# OUTPUT_DIR=/path/to/output
# VIDEO_OUTPUT_DIR=/path/to/video_output

# Optional: Default API preference
# DEFAULT_API=openai
